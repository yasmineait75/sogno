{
    "version": 2,
    "buildCommand": "cd frontend && yarn install --frozen-lockfile && yarn build",
    "outputDirectory": "frontend/build",
    "installCommand": "pip install -r api/requirements.txt",
    "framework": null,
    "rewrites": [
          { "source": "/api/(.*)", "destination": "/api/index" }
    ],
    "functions": {
          "api/index.py": {
                  "runtime": "@vercel/python@4.3.1",
                  "maxDuration": 30
          }
    }
}
